import sys
import signal
import logging
from logger_hub import logger_hub  # Integrated Logging
from vision_engine import JarvisVisionEngine  # Integrated Vision
from secure_vault import MohammadVaultEngine  # Integrated Banking

class JarvisMainframe:
    """
    Unified Jarvis Core: Orchestrates Vision, Security, and Intelligence.
    """
    def __init__(self):
        self.vision = JarvisVisionEngine()
        self.vault = MohammadVaultEngine()
        self.running = True
        
        # Signal handling for safety
        signal.signal(signal.SIGINT, self.shutdown)
        signal.signal(signal.SIGTERM, self.shutdown)

    def start(self):
        logger_hub.system.info("Jarvis Core Mainframe Online.")
        try:
            # Example: Run Vision analysis as a core background service
            self.vision.run_realtime_analysis()
        except Exception as e:
            logger_hub.error.critical(f"System Critical Failure: {e}")
            self.shutdown()

    def shutdown(self, *args):
        logger_hub.system.info("Graceful shutdown initiated.")
        self.running = False
        sys.exit(0)

if __name__ == "__main__":
    mainframe = JarvisMainframe()
    mainframe.start()
